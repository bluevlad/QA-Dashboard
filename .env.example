# QA-Dashboard Environment Configuration
# Copy this file to .env and fill in your values
# All variables are prefixed with QD_ for namespace isolation

# Database Configuration
QD_DB_HOST=localhost
QD_DB_PORT=5432
QD_DB_NAME=qa_dashboard
QD_DB_USER=postgres
QD_DB_PASSWORD=your_secure_password_here

# Log directory (for file-based auto-sync)
QD_LOG_DIR=/app/logs

# Sync interval in seconds
QD_SYNC_INTERVAL=60
