# QA-Dashboard Environment Configuration
# Copy this file to .env and fill in your values
# All variables are prefixed with QA_DASHBOARD_ for namespace isolation

# Database Configuration (full connection URL)
QA_DASHBOARD_DATABASE_URL=postgresql://qa_dashboard_svc:your_password@host.docker.internal:5432/qa_dashboard

# API Key for ingest authentication (Bearer token)
QA_DASHBOARD_API_KEY=qa-agent-secret-key

# CORS allowed origins (comma-separated)
QA_DASHBOARD_CORS_ORIGINS=*

# Log directory (for file-based auto-sync)
QA_DASHBOARD_LOG_DIR=/app/logs

# Sync interval in seconds
QA_DASHBOARD_SYNC_INTERVAL=60

# --- Auth Configuration ---
# Google OAuth
QA_AUTH_GOOGLE_CLIENT_ID=your-google-client-id
QA_AUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT
QA_AUTH_JWT_SECRET_KEY=change-me-in-production
QA_AUTH_SESSION_SECRET_KEY=change-me-session-secret

# URLs (must match your reverse proxy)
QA_AUTH_FRONTEND_URL=https://admin.unmong.com/qa
QA_AUTH_BACKEND_URL=https://admin.unmong.com/qa

# Allowed admin emails (comma-separated)
QA_AUTH_ADMIN_EMAILS=admin@example.com
